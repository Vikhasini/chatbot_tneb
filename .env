# Local development environment — DO NOT commit this file
FLASK_ENV=development
SECRET_KEY=tneb-local-dev-secret-key-change-in-prod

# ── LOCAL PostgreSQL ────────────────────────────────────────────────────────
# Option A: Local PostgreSQL (if you have it installed)
DATABASE_URL=postgresql://postgres:password@localhost/tneb_portal

# Option B: If you want to use a free cloud Postgres for local dev, paste Render URL here:
# DATABASE_URL=postgresql://user:pass@host/dbname
