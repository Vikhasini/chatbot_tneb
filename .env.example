# ── TNEB Email Support Portal — Environment Variables ──────────────────────
# Copy this to .env for local development (never commit .env to git).
#
# On Render, set these under:
#   Dashboard → Your Web Service → Environment → Add Environment Variable

# ── Required ────────────────────────────────────────────────────────────────
# Get this from Render → Your PostgreSQL → Connect → Internal Database URL
DATABASE_URL=postgresql://user:password@host/dbname

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── Optional (Render sets these automatically) ───────────────────────────────
FLASK_ENV=production
PORT=5000
